root = true

[*]
end_of_line = lf
charset = utf-8

[*.nix]
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 2
indent_style = space

[justfile]
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 8

[*.toml]
indent_size = 2
indent_style = space
